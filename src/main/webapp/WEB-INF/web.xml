<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
         http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

  <display-name>AttendEase</display-name>

  <servlet>
    <servlet-name>AddEmployeeServlet</servlet-name>
    <servlet-class>AddEmployeeServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>AddEmployeeServlet</servlet-name>
    <url-pattern>/addEmployee</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>GetEmployeesServlet</servlet-name>
    <servlet-class>GetEmployeesServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>GetEmployeesServlet</servlet-name>
    <url-pattern>/getEmployees</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>MarkAttendanceServlet</servlet-name>
    <servlet-class>MarkAttendanceServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>MarkAttendanceServlet</servlet-name>
    <url-pattern>/markAttendance</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>GetAttendanceServlet</servlet-name>
    <servlet-class>GetAttendanceServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>GetAttendanceServlet</servlet-name>
    <url-pattern>/getAttendance</url-pattern>
  </servlet-mapping>

</web-app>